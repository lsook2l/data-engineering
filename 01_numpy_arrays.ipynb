# NumPy 불러오기
import numpy as np





# [+] 리스트 객체로부터 ndarray 객체 생성
my_lst = [1,2,3,4,5,6]
my_arr = np.array

my_arr


# [+] 리스트/NumPy 배열 동시에 생성
np.array([1,2,3,4,5])





# [+] 리스트 컴프리헨션을 이용하여 5달러씩 가격을 일괄적으로 할인하기
prices = [20, 40, 35, 10, 25, 56]
new_prices = [prices-5 for prices in prices]

new_prices


# [+] NumPy 배열의 연산을 통한 5달러씩 가격을 일괄적으로 할인하기
prices_arr = np.array(new_prices)  # 배열 생성
prices_arr = prices_arr + 5    # 가격 수정

prices_arr





# 세 번의 시험에 대한 점수를 NumPy 배열로 선언
test_1 = np.array([92, 94, 88, 91, 87])
test_2 = np.array([79, 100, 86, 93, 91])
test_3 = np.array([87, 85, 72, 90, 92])


# [+] 세 번째 시험에 2점씩 더하기
test_3_fixed = test_3 + 2

test_3_fixed


# [+] 학생 별 전체 시험 점수 총합 계산 
total_grade = test_1 + test_2 + test_3_fixed

total_grade


# [+] 학생 별 평균 시험 점수 계산
final_grade = total_grade / 3

final_grade


# [+] 인덱싱: Jeremy의 두 번째 시험 점수
jeremy_test_2 = test_2[3]

jeremy_test_2


# [+] Manual과 Adwoa의 첫 번째 시험 점수
manual_adwoa_test_1 = test_1[1], test_1[2]

manual_adwoa_test_1


# [+] 전체 학생들의 점수를 2차원 배열에 저장
student_scores = np.array([test_1, test_2, test_3_fixed])

student_scores # 가로 방향이 아니라 세로 방향으로 쌓아짐, 2차원으로 됨


# [+] 2차원 배열 인덱싱: Tanya의 세 번째 시험 점수 arr[row_index,column_index]
student_scores[2,0]


# [+] 2차원 배열 슬라이싱: Cody의 전체 시험 점수
student_scores[0:3, 4:5] #[:3, 4]





a = np.array([1, 20, 4, 6, 28, 88, 7, 12])

# [+] 10 이상 여부를 마스킹
mask = a >= 10

mask


# [+] 논리 연산을 이용하여 부분집합 구하기
selected = a[a >= 10] #조건식의 결과가 트루인 a중의 데이터 선택

selected


# [+] 논리식 결합: 논리합 '|'
selected = a[(a > 6) | (a < 4)] # 6보다 크거나 4보다 작은 경우의 a중의 데이터 값

selected


# [+] 논리식 결합: 논리곱 '&'
selected = a[(a > 10) & (a < 30)]

selected


# [+] 정수 배열 생성, arange(stop)
np.arange(10) # ndarray 배열 생성 #인자=argument


# [+] 정수 배열 생성, arange(start, stop)
np.arange(10,20) # start부터 stop-1까지


# [+] 정수 배열 생성, arange(start, stop, interval)
np.arange(10,20,3) # 3칸씩


# [+] 난수 배열 생성
np.random.seed(0) # seed값 = 티비 채널, 매번 같은 값의 랜덤값 생성
arr = np.random.randint(10, size=(3,5)) # 랜덤한 10개의 수, 난수 배열의 크기(3행 5열)

arr





# [+] 배열 속성
print(arr.ndim)     # 차원 수
print(arr.shape)    # 형상(차원 크기) -> np.reshape(): 배열 차원 재형성
print(arr.size)     # 전체 배열 크기
print(arr.dtype)    # 데이터 타입
print(arr.itemsize)  # 원소별 메모리 크기(bytes)
print(arr.nbytes)   # 전체 메모리 크기


# 배열 슬라이싱
arr = np.arange(10)
print(arr)

print(arr[3:7]) # 슬라이싱(start:stop)
print(arr[:5]) # 시작 인덱스 생략(:stop)
print(arr[5:]) # 종료 인덱스 생략(start:)
print(arr[::3]) # 간격(::interval)
print(arr[2:8:2]) # 슬라이싱(start:stop:interval)


# 난수 배열 생성
np.random.seed(0) 
arr = np.random.randint(10, size=(6, 8)) # 6행 8열

arr


# [+] 다차원 배열 슬라이싱
arr[3:5, 4:7] # 슬라이싱 결과는 새로운 배열이 되는 것


# 배열 슬라이스 = 뷰(view) = 돋보기로 보겠다.
arr_sub = arr[:2, :2]
print(arr_sub)

arr_sub[0, 0] = 99
print(arr_sub)

print(arr) # 복사본이 아니니 뷰에서 변경한 사항이 원본 객체에도 적용됨


# 배열 복사본 생성
arr_sub = arr[:2, :2].copy()

arr_sub[0, 0] = 50
print(arr_sub)

print(arr) # 따로 메모리를 차지하는 복사본을 수정했기에 원본에는 영향을 주지 않음


# [+] 배열 재구조화: reshape()
# 원소 개수가 변경 전후와 같아야 함
x = np.arange(10) # 0~9로 이루어진 배열 생성 (10,)
print(x)
print(x.shape)

x_reshaped = x.reshape(2,5) # 배열을 2X5 형상으로 재구조화
print(x_reshaped)
print(x_reshaped.shape)


# [+] 배열 재구조화: 차원 추가(np.newaxis)
arr = np.arange(3)
arr_new = arr[np.newaxis,:] # or arr_new = arr [:, np.newaxis] 두 가지 종류로 추가 가능
print(arr_new)
print(arr_new.shape)





# 세 개의 배열 생성
arr_1 = np.arange(1, 4)
arr_2 = np.arange(4, 7)
arr_3 = np.arange(7, 10)

print(arr_1, arr_2, arr_3)


# [+] 배열 연결: np.concatenate() - 가로
np.concatenate([arr_1, arr_2, arr_3])


# [+] 배열 연결: 종(세로)연결 vertical()
np.vstack([arr_1, arr_2, arr_3])


# 배열 연결: 횡(가로)연결 = np.concatenate()
np.hstack([arr_1, arr_2, arr_3])


arr = [1, 2, 3, 99, 99, 3, 2, 1]
print(arr)

# [+] 배열 분할 [1,2,3], [99,99], [3,2,1]
arr_1, arr_2, arr_3 = np.split(arr,[3,5])
print(arr_1, arr_2, arr_3)
